#!/bin/bash
#
# Cloud Floating IP Failover Script (Hetzner Cloud)
# Reassigns the Hetzner Floating IP to the current MASTER node on VRRP transition.
# Part of: ansible-role-haproxy-keepalived
#
# Credentials are NOT baked in: they are sourced from a 0600 env file.
#

set -euo pipefail

ENV_FILE="/etc/keepalived/cloud-floating-ip.env"
if [ -r "$ENV_FILE" ]; then
    # shellcheck disable=SC1090
    source "$ENV_FILE"
fi

FLOATING_IP_INTERFACE="{{ cloud_floating_ip_interface }}"
SERVER_NAME="{{ cloud_server_name }}"
API_ENDPOINT="{{ cloud_api_endpoint }}"
LOG_FILE="{{ cloud_floating_ip_log }}"

log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE" >/dev/null
}

for cmd in curl jq; do
    if ! command -v "$cmd" &> /dev/null; then
        log "ERROR: $cmd not found - required for cloud API calls"
        exit 1
    fi
done

: "${CLOUD_API_TOKEN:?CLOUD_API_TOKEN not set in $ENV_FILE}"
: "${FLOATING_IP:?FLOATING_IP not set in $ENV_FILE}"

CURL="curl -fsS --connect-timeout 5 --max-time 20 --retry 3 --retry-delay 2 --retry-connrefused"

STATE="${1:-UNKNOWN}"
log "Keepalived state transition: $STATE on server $SERVER_NAME"

assign_floating_ip() {
    SERVER_ID=$($CURL -H "Authorization: Bearer $CLOUD_API_TOKEN" \
        "${API_ENDPOINT}/servers?name=${SERVER_NAME}" \
        | jq -r --arg n "$SERVER_NAME" '.servers[] | select(.name==$n) | .id' | head -1)
    if [ -z "$SERVER_ID" ] || [ "$SERVER_ID" = "null" ]; then
        log "ERROR: Could not find server ID for $SERVER_NAME"
        exit 1
    fi
    log "Found server ID: $SERVER_ID"

    FIP_ID=$($CURL -H "Authorization: Bearer $CLOUD_API_TOKEN" \
        "${API_ENDPOINT}/floating_ips?ip=${FLOATING_IP}" \
        | jq -r --arg ip "$FLOATING_IP" '.floating_ips[] | select(.ip==$ip) | .id' | head -1)
    if [ -z "$FIP_ID" ] || [ "$FIP_ID" = "null" ]; then
        log "ERROR: Could not find Floating IP ID for ${FLOATING_IP}"
        exit 1
    fi
    log "Found Floating IP ID: $FIP_ID"

    ASSIGN_RESPONSE=$($CURL -X POST \
        -H "Authorization: Bearer $CLOUD_API_TOKEN" \
        -H "Content-Type: application/json" \
        -d "{\"server\": $SERVER_ID}" \
        "${API_ENDPOINT}/floating_ips/${FIP_ID}/actions/assign" || true)

    if echo "$ASSIGN_RESPONSE" | jq -e '.action' >/dev/null 2>&1; then
        log "SUCCESS: Floating IP $FLOATING_IP assigned to $SERVER_NAME"
    elif echo "$ASSIGN_RESPONSE" | jq -e '.error.code == "locked"' >/dev/null 2>&1; then
        log "Floating IP already assigned to this server (treating as success)"
    else
        log "ERROR: Failed to assign Floating IP via API"
        exit 1
    fi
}

add_floating_ip_to_interface() {
    if ! ip addr show "$FLOATING_IP_INTERFACE" | grep -q "$FLOATING_IP"; then
        ip addr add "${FLOATING_IP}/32" dev "$FLOATING_IP_INTERFACE"
        log "Added $FLOATING_IP/32 to interface $FLOATING_IP_INTERFACE"
    fi
}

remove_floating_ip_from_interface() {
    if ip addr show "$FLOATING_IP_INTERFACE" | grep -q "$FLOATING_IP"; then
        ip addr del "${FLOATING_IP}/32" dev "$FLOATING_IP_INTERFACE"
        log "Removed $FLOATING_IP/32 from interface $FLOATING_IP_INTERFACE"
    fi
}

case "$STATE" in
    MASTER)
        assign_floating_ip
        add_floating_ip_to_interface
        log "MASTER setup complete - Floating IP $FLOATING_IP active on $SERVER_NAME"
        ;;
    BACKUP|FAULT)
        log "Transitioning to $STATE - flushing local Floating IP"
        remove_floating_ip_from_interface
        ;;
    *)
        log "Unknown state: $STATE"
        ;;
esac

exit 0
